# .npmrc
# ─────────────────────────────────────────────────────────────────────
# npm configuration for Cloudflare Pages builds.
#
# CF Pages automatically caches node_modules between builds when the
# package-lock.json hash hasn't changed.  These settings help npm make
# the most of that cache on warm builds and stay strict on cold ones.
#
# prefer-offline     — use the local cache before making network requests.
#                      On a CF Pages warm build, packages are already on
#                      disk; this tells npm to skip the registry check.
#
# legacy-peer-deps   — false (the default) enforces strict peer dep
#                      resolution.  Explicit here so CI doesn't silently
#                      downgrade if someone runs npm install locally with
#                      a different npm version that has different defaults.
#
# fund               — false suppresses the "N packages are looking for
#                      funding" message in build logs (cosmetic only).
#
# audit              — false skips the security audit that runs at the
#                      end of npm install.  CF builds are not the right
#                      place to gate on audits; use Dependabot or a
#                      dedicated audit step in a separate CI job.
# ─────────────────────────────────────────────────────────────────────

prefer-offline=true
legacy-peer-deps=false
fund=false
audit=false
