---
import BaseLayout from './BaseLayout.astro';
import PageSEO from '@/components/seo/PageSEO.astro';
import MainNavbar from '@/components/shared/MainNavbar';
import '@/styles/global.css';

export interface SidebarLink {
  id: string;
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  routeKey: string;
  sidebarTitle?: string;
  sidebarLinks?: SidebarLink[];
  searchPlaceholder?: string;
}

const {
  title,
  description,
  canonical,
  routeKey,
  sidebarTitle = 'Table of Contents',
  sidebarLinks = [],
  searchPlaceholder = 'Search...',
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  bodyClass="bg-[#070706]"
>
  <PageSEO slot="head" routeKey={routeKey} />

  <div style="min-height: 100dvh; background: var(--film-black); color: var(--film-cream);">
    <MainNavbar
      client:load
      search={{
        value: '',
        placeholder: searchPlaceholder,
        readOnly: true,
        onActivate: undefined,
      }}
      keepSearchOnMobile
      showMobileBuildCta
    />

    <main id="main-content" class="docs-layout-main">
      <aside class="docs-layout-sidebar">
        <div
          class="syne-font"
          style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--film-text-dim); margin-bottom: 10px;"
        >
          {sidebarTitle}
        </div>
        <nav style="display: flex; flex-direction: column; gap: 6px;">
          {sidebarLinks.map((link) => (
            <a
              href={link.href}
              class="hover-cream syne-font docs-sidebar-link"
              data-sidebar-link={link.id}
              style="text-decoration: none; color: var(--film-text-label); font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; padding: 6px 8px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.02);"
            >
              {link.label}
            </a>
          ))}
        </nav>
        <slot name="sidebar-footer" />
      </aside>

      <section style="display: flex; flex-direction: column; gap: 18px;">
        <slot />
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .docs-sidebar-link[data-active="true"] {
    color: var(--film-cream) !important;
    border-color: rgba(212,162,69,0.5) !important;
    background: rgba(196,124,46,0.2) !important;
  }
</style>
