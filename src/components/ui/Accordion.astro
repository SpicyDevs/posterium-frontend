---
interface Props {
  title: string;
  id?: string;
  defaultOpen?: boolean;
}

const { title, id, defaultOpen = false } = Astro.props;
const baseId = (id ?? title)
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '');
const summaryId = `accordion-summary-${baseId}`;
const panelId = `accordion-panel-${baseId}`;
---

<details
  class="faq-accordion"
  data-accordion-id={id}
  open={defaultOpen}
  style="border: 1px solid rgba(196,124,46,0.14); background: rgba(24,22,18,0.6); border-radius: 10px; overflow: hidden;"
>
  <summary
    id={summaryId}
    role="button"
    aria-controls={panelId}
    aria-expanded={defaultOpen ? 'true' : 'false'}
    style="width: 100%; cursor: pointer; background: rgba(255,255,255,0.01); display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; color: var(--film-cream); list-style: none;"
  >
    <span
      class="syne-font"
      style="font-size: 13px; font-weight: 700; letter-spacing: 0.02em;"
    >
      {title}
    </span>
    <svg
      class="accordion-chevron"
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      style="transition: transform 0.2s ease; flex-shrink: 0;"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </summary>
  <div
    id={panelId}
    role="region"
    aria-labelledby={summaryId}
    style="border-top: 1px solid rgba(196,124,46,0.12); padding: 14px 16px; color: var(--film-text-body); font-size: 14px; line-height: 1.7;"
  >
    <div class="prose prose-compact">
      <slot />
    </div>
  </div>
</details>

<style>
  .faq-accordion summary::-webkit-details-marker {
    display: none;
  }

  .faq-accordion[open] .accordion-chevron {
    transform: rotate(180deg);
  }
</style>
