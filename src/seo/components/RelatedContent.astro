---
import type { RelatedContentLink } from '@/lib/internal-links';

interface Props {
  links?: RelatedContentLink[];
  title?: string;
}

const { links = [], title = 'Related content' } = Astro.props;
---

{
  links.length > 0 && (
    <section
      aria-label={title}
      style="margin-top: 18px; border: 1px solid rgba(196,124,46,0.14); background: rgba(14,13,11,0.72); border-radius: 12px; padding: 14px;"
    >
      <h2
        class="syne-font"
        style="margin: 0 0 10px; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--film-pale);"
      >
        {title}
      </h2>
      <nav aria-label="Contextual internal links">
        <ul style="margin: 0; padding: 0; list-style: none; display: grid; gap: 8px;">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="hover-cream syne-font"
                style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none; color: var(--film-cream); font-size: 12px; letter-spacing: 0.04em;"
              >
                <span style="opacity: 0.7; text-transform: uppercase; font-size: 10px;">{link.collection}</span>
                <span>{link.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </section>
  )
}
