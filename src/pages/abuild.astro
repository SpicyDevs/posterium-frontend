---
// src/pages/abuild.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSEO from '@/components/seo/PageSEO.astro';
import AdvancedBuilderApp from '@/components/builder/AdvancedBuilderApp.tsx';
import '@/styles/global.css';
---

<BaseLayout
  title="Poster Builder - Simple & Advanced Editor | Posterium"
  description="Unified Posterium poster editor with simple and advanced modes, vertical panel navigation, drag-and-drop badge positioning, and live exports."
  canonical="https://posters.spicydevs.xyz/build"
  bodyClass="overflow-hidden"
>
  <PageSEO slot="head" routeKey="/build" />

  <div class="sr-only">
    <h2>Posterium Unified Advanced Builder</h2>
    <p>Advanced visual editor with vertical panel navigation for creating custom movie and TV posters with live rating badges.</p>
  </div>

  <AdvancedBuilderApp client:only="react" />
</BaseLayout>