---
// src/pages/index.astro
//
// The hero-anims-active class is included on <body> at render time so that
// CSS animation-fill-mode:backwards keeps the h-a* elements in their "from"
// state (opacity:0, translated) from the very first paint.  This avoids the
// visible→invisible flash that occurred when the class was added via a
// DOMContentLoaded script after the SSR content had already been painted.
// Animations are CSS-only and require no JavaScript.

import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSEO from '@/components/seo/PageSEO.astro';
import Dashboard from '@/components/dashboard/Dashboard.tsx';
import '@/styles/global.css';
---

<BaseLayout
  title="Posterium - Free Movie & TV Poster Generator with Live Ratings"
  description="Generate custom movie and TV show posters with IMDb, Rotten Tomatoes, Metacritic, TMDB, Letterboxd, and MAL rating badges. Free API - no account required. Perfect for Plex, Jellyfin, Discord bots, Notion, and more."
  canonical="https://posters.spicydevs.xyz"
  bodyClass="bg-[#070706] hero-anims-active"
>
  <PageSEO slot="head" routeKey="/" />
  <Dashboard client:load />
</BaseLayout>
