---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSEO from '@/components/seo/PageSEO.astro';
import Dashboard from '@/components/dashboard/Dashboard.tsx';
import '@/styles/global.css';
---

<BaseLayout
  title="Posterium - Free Movie & TV Poster Generator with Live Ratings"
  description="Generate custom movie and TV show posters with IMDb, Rotten Tomatoes, Metacritic, TMDB, Letterboxd, and MAL rating badges. Free API - no account required. Perfect for Plex, Jellyfin, Discord bots, Notion, and more."
  canonical="https://posters.spicydevs.xyz"
  bodyClass="bg-[#070706]"
>
  <PageSEO slot="head" routeKey="/" />
  {/* Keep SSR HTML and hydrate on load so hero intro starts promptly once JS boots */}
  <Dashboard client:load />
</BaseLayout>
