---
// src/pages/test.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestBenchmark from '../../components/TestBenchmark';
import { SITE_CONFIG } from '@/constants/site';
import type { PageSEOMetadata } from '@/types/seo';

const canonical = `${SITE_CONFIG.baseUrl}/admin/test`;
const seo: PageSEOMetadata = {
  title: 'Rasterizer Benchmark | Posterium',
  description: 'Test all rasterizer nodes with live poster timing and health data.',
  canonical,
  ogImage: SITE_CONFIG.ogImageUrl,
  ogImageAlt: 'Posterium rasterizer benchmark dashboard',
  robots: 'noindex, nofollow',
  breadcrumbs: [
    { name: 'Home', url: SITE_CONFIG.baseUrl },
    { name: 'Rasterizer Benchmark', url: canonical },
  ],
  jsonLd: [],
};
---

<BaseLayout seo={seo}>
  <TestBenchmark client:only="react" />
</BaseLayout>
