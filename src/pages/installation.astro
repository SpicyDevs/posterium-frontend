---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSEO from '@/components/seo/PageSEO.astro';
import MainNavbar from '@/components/shared/MainNavbar';
import ShowcaseViewer from '@/components/installation/ShowcaseViewer';
import TableOfContentsClient from '@/components/TableOfContentsClient';
import { AmberTag } from '@/components/shared/primitives';
import { extractMarkdownHeadings } from '@/lib/markdown-headings';
import '@/styles/global.css';

// Default placeholder images
const placeholderImages = {
  desktop: '/placeholders/install-desktop.svg',
  tv: '/placeholders/install-tv.svg',
  mobile: ['/placeholders/install-mobile.svg', '/placeholders/install-mobile-alt.svg'],
};

// Get all installation guides at build time
const installEntries = await getCollection('install');

// Sort by order
const sortedGuides = installEntries.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

// Prepare guides with extracted headings (content is pre-rendered via glob loader)
const preparedGuides = sortedGuides.map((guide) => {
  const headings = extractMarkdownHeadings(guide.body ?? '');
  const name = guide.data.name ?? guide.id.charAt(0).toUpperCase() + guide.id.slice(1);
  const showcaseImages = guide.data.showcaseImages ?? placeholderImages;
  const html = guide.rendered?.html ?? '';
  return { guide, headings, name, showcaseImages, html };
});

// Build sidebar links
const sidebarLinks = preparedGuides.map((g) => ({
  id: g.guide.id,
  label: g.name,
  href: `#${g.guide.id}`,
}));
---

<BaseLayout
  title="Installation - Posterium"
  description="Installation guides for using Posterium with Plex, Emby, Jellyfin, Stremio, Kodi, and other media apps."
  canonical="https://posters.spicydevs.xyz/installation"
  bodyClass="bg-[#070706]"
>
  <PageSEO slot="head" routeKey="/installation" />

  <div style="min-height: 100dvh; background: var(--film-black); color: var(--film-cream);">
    <MainNavbar
      client:load
      search={{
        value: '',
        placeholder: 'Search guides...',
        readOnly: true,
      }}
      keepSearchOnMobile
      showMobileBuildCta
    />

    <main class="docs-layout-main">
      <aside class="docs-layout-sidebar">
        <div
          class="syne-font"
          style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--film-text-dim); margin-bottom: 10px;"
        >
          Apps
        </div>
        <nav id="app-nav" style="display: flex; flex-direction: column; gap: 6px;">
          {sidebarLinks.map((link, idx) => (
            <a
              href={link.href}
              class="hover-cream syne-font docs-sidebar-link"
              data-app-link={link.id}
              style={`text-decoration: none; color: ${idx === 0 ? 'var(--film-cream)' : 'var(--film-text-label)'}; font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; padding: 6px 8px; border-radius: 6px; border: 1px solid ${idx === 0 ? 'rgba(212,162,69,0.5)' : 'rgba(255,255,255,0.06)'}; background: ${idx === 0 ? 'rgba(196,124,46,0.2)' : 'rgba(255,255,255,0.02)'};`}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Table of Contents for active guide -->
        <div id="toc-container" style="margin-top: 14px;">
          {preparedGuides[0] && (
            <TableOfContentsClient client:idle headings={preparedGuides[0].headings} />
          )}
        </div>
      </aside>

      <section style="display: flex; flex-direction: column; gap: 18px;">
        <!-- Page Header -->
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
          <div>
            <h1
              class="poster-font"
              style="margin: 0; font-size: clamp(38px,7vw,64px); letter-spacing: 0.08em; line-height: 0.9;"
            >
              Installation
            </h1>
            <p
              class="body-font"
              style="margin: 10px 0 0; color: var(--film-text-dim); font-size: 14px;"
            >
              Setup Posterium in Plex, Emby, Jellyfin, Stremio, Kodi, and more.
            </p>
          </div>
          <AmberTag>{preparedGuides.length} apps</AmberTag>
        </div>

        <!-- Installation Guide Articles (Static HTML) -->
        {preparedGuides.map(({ guide, name, showcaseImages, html }, index) => (
          <article
            id={guide.id}
            data-guide-id={guide.id}
            style={`scroll-margin-top: 88px; border: 1px solid rgba(196,124,46,0.14); background: rgba(14,13,11,0.72); border-radius: 12px; padding: 14px 14px 16px; display: ${index === 0 ? 'flex' : 'none'}; flex-direction: column; gap: 14px; width: 100%; max-width: 100%; overflow: hidden;`}
          >
            <h2
              class="syne-font"
              style="margin: 0; font-size: 15px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--film-pale);"
            >
              {name}
            </h2>

            <!-- Showcase Viewer (React island for device switching) -->
            <ShowcaseViewer
              client:visible
              appName={name}
              images={showcaseImages}
              placeholderImages={placeholderImages}
            />

            <!-- Guide Content (Static markdown) -->
            <section
              style="border: 1px solid rgba(196,124,46,0.16); background: rgba(10,10,9,0.66); border-radius: 12px; padding: 14px;"
            >
              <h3
                class="syne-font"
                style="margin: 0 0 12px; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--film-pale);"
              >
                Guide
              </h3>
              <div class="prose" set:html={html} />
            </section>
          </article>
        ))}
      </section>
    </main>
  </div>
</BaseLayout>

<script define:vars={{ guideIds: preparedGuides.map(g => g.guide.id), guideHeadings: preparedGuides.map(g => ({ id: g.guide.id, headings: g.headings })) }}>
  // App navigation switching
  const appLinks = document.querySelectorAll('[data-app-link]');
  const guideArticles = document.querySelectorAll('[data-guide-id]');

  const setActiveGuide = (guideId) => {
    // Update sidebar links
    appLinks.forEach((link) => {
      const isActive = link.dataset.appLink === guideId;
      link.style.color = isActive ? 'var(--film-cream)' : 'var(--film-text-label)';
      link.style.borderColor = isActive ? 'rgba(212,162,69,0.5)' : 'rgba(255,255,255,0.06)';
      link.style.background = isActive ? 'rgba(196,124,46,0.2)' : 'rgba(255,255,255,0.02)';
    });

    // Show/hide guide articles
    guideArticles.forEach((article) => {
      article.style.display = article.dataset.guideId === guideId ? 'flex' : 'none';
    });
  };

  // Handle click on app links
  appLinks.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const guideId = link.dataset.appLink;
      if (guideId) {
        setActiveGuide(guideId);
        // Update URL hash
        history.pushState(null, '', `#${guideId}`);
      }
    });
  });

  // Handle initial hash
  const initialHash = window.location.hash.slice(1);
  if (initialHash && guideIds.includes(initialHash)) {
    setActiveGuide(initialHash);
  }

  // Handle hash change
  window.addEventListener('hashchange', () => {
    const hash = window.location.hash.slice(1);
    if (hash && guideIds.includes(hash)) {
      setActiveGuide(hash);
    }
  });
</script>
