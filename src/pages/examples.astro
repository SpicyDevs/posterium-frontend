---
// src/pages/examples.astro
//
// PERF: Changed client:load → client:visible.
// The examples grid is fully below the fold on load; there is zero reason to
// block the main thread hydrating it before the user has even scrolled to it.

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSEO from '@/components/seo/PageSEO.astro';
import ExamplesPage from '@/components/examples/ExamplesPage';
import { SITE_CONFIG } from '@/lib/config';
import { createItemListSchema } from '@/lib/seo/schemas';
import '@/styles/global.css';

const exampleEntries = await getCollection('examples');

const presets = exampleEntries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((entry) => ({
    id:          entry.id,
    title:       entry.data.title,
    description: entry.data.description,
    query:       entry.data.query,
  }));

const presetSchema = createItemListSchema(
  'Posterium preset showcase',
  presets.map((preset) => ({
    name: preset.title,
    description: preset.description,
    url: `${SITE_CONFIG.baseUrl}/examples#${preset.id}`,
  })),
  'Examples of ready-made Posterium poster configurations.'
);
---

<BaseLayout
  title="Examples - Posterium"
  description="Explore stylish poster examples and open any configuration directly in the Posterium builder."
  canonical="https://posters.spicydevs.xyz/examples"
  bodyClass="bg-[#070706]"
>
  <PageSEO slot="head" routeKey="/examples" additionalSchemas={[presetSchema]} />

  <!--
    client:visible — only hydrate once the component scrolls into the viewport.
    The MainNavbar inside ExamplesPage uses client:load, but the gallery grid
    itself has no above-the-fold interactivity that justifies eager hydration.
  -->
  <ExamplesPage client:visible presets={presets} />
</BaseLayout>
