---
// src/pages/examples.astro
//
// PERF: Changed client:load → client:visible.
// The examples grid is fully below the fold on load; there is zero reason to
// block the main thread hydrating it before the user has even scrolled to it.

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ExamplesPage from '@/components/examples/ExamplesPage';
import { SITE_CONFIG } from '@/lib/config';
import { buildArticleOrTechArticleSchema, type PageSEOMetadata } from '@/lib/seo';
import '@/styles/global.css';

const exampleEntries = await getCollection('examples');

const sortedExamples = exampleEntries.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const presets = sortedExamples.map((entry) => ({
  id:          entry.id,
  title:       entry.data.title,
  description: entry.data.description,
  query:       entry.data.query,
}));

const canonical = `${SITE_CONFIG.baseUrl}/examples`;

const seo: PageSEOMetadata = {
  title: 'Examples - Posterium',
  description: 'Explore stylish poster examples and open any configuration directly in the Posterium builder.',
  keywords: 'posterium examples, poster showcase, movie poster examples, export poster api urls, open in builder',
  canonical,
  ogImage: SITE_CONFIG.ogImageUrl,
  ogImageAlt: 'Posterium example movie poster layouts with rating badges',
  robots: 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  breadcrumbs: [
    { name: 'Home', url: SITE_CONFIG.baseUrl },
    { name: 'Examples', url: canonical },
  ],
  jsonLd: sortedExamples.map((entry) => buildArticleOrTechArticleSchema({ ...entry, slug: `examples/${entry.id}` })),
};
---

<BaseLayout
  seo={seo}
  bodyClass="bg-[#070706]"
>

  <!--
    client:visible — only hydrate once the component scrolls into the viewport.
    The MainNavbar inside ExamplesPage uses client:load, but the gallery grid
    itself has no above-the-fold interactivity that justifies eager hydration.
  -->
  <ExamplesPage client:visible presets={presets} />
</BaseLayout>
