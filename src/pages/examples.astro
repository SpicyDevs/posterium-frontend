---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSEO from '@/components/seo/PageSEO.astro';
import ExamplesPage from '@/components/examples/ExamplesPage';
import '@/styles/global.css';

// Get all examples at build time from content collection
const exampleEntries = await getCollection('examples');

// Sort by order and transform to match ExamplePreset interface
const presets = exampleEntries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((entry) => ({
    id: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    query: entry.data.query,
  }));
---

<BaseLayout
  title="Examples - Posterium"
  description="Explore stylish poster examples and open any configuration directly in the Posterium builder."
  canonical="https://posters.spicydevs.xyz/examples"
  bodyClass="bg-[#070706]"
>
  <PageSEO slot="head" routeKey="/examples" />
  <ExamplesPage client:load presets={presets} />
</BaseLayout>
