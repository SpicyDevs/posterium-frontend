---
// src/pages/404.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import NotFound from '@/modules/NotFound.tsx';
import '@/styles/global.css';
import { SITE_CONFIG } from '@/constants/site';
import type { PageSEOMetadata } from '@/types/seo';

const canonical = `${SITE_CONFIG.baseUrl}/404`;
const seo: PageSEOMetadata = {
  title: 'Page Not Found | Posterium',
  description: 'The page you are looking for does not exist.',
  canonical,
  ogImage: SITE_CONFIG.ogImageUrl,
  ogImageAlt: 'Posterium page not found',
  robots: 'noindex, nofollow',
  breadcrumbs: [
    { name: 'Home', url: SITE_CONFIG.baseUrl },
    { name: '404', url: canonical },
  ],
  jsonLd: [],
};
---

<BaseLayout seo={seo}>
  <main id="main-content">
    <NotFound client:only="react" />
  </main>
</BaseLayout>
