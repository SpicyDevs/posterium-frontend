{
  "name": "posterium-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "prebuild-push": "npm run clean",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy --env production",
    "release:staging": "npm run typecheck && npm run test && npm run build && npm run deploy:staging",
    "cf:dev": "wrangler dev"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@hello-pangea/dnd": "^18.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^5.0.0",
    "astro-compress": "^2.4.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.4.35",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.2.2",
    "vitest": "^4.1.1",
    "wrangler": "^4.78.0"
  }
}
